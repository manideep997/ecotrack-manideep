generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  totalPoints   Int       @default(0)
  currentLevel  Int       @default(1)
  
  cityId        String?
  cityProfile   CityProfile? @relation(fields: [cityId], references: [id])
  
  accounts      Account[]
  sessions      Session[]
  activities    Activity[]
  goals         UserGoal[]
  badges        Badge[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Activity {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  cityId         String?
  cityProfile    CityProfile? @relation(fields: [cityId], references: [id])
  
  category       String       // TRAVEL, ELECTRICITY, FOOD, LIFESTYLE
  subcategory    String       // e.g., "Car", "Flight", "Beef"
  inputValue     Float        // e.g., 50 (miles)
  unit           String       // e.g., "miles", "kWh", "servings"
  co2Emitted     Float        // Calculated CO2 in kg
  date           DateTime     @default(now())
}

model Recommendation {
  id               String     @id @default(cuid())
  category         String
  title            String
  description      String
  potentialSavings Float      // Estimated CO2 savings in kg
}

model UserGoal {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  description    String
  targetDate     DateTime
  isCompleted    Boolean      @default(false)
}

model Badge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String
  earnedAt    DateTime @default(now())
  iconUrl     String?
}

model CityProfile {
  id                String       @id @default(cuid())
  name              String       @unique
  electricityFactor Float        // kg CO2 per kWh
  transitFactor     Float        // kg CO2 per mile (public transit)
  
  users             User[]
  activities        Activity[]
}
